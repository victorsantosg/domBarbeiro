# Database Configuration (Docker)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=barber_shop
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/barber_shop?schema=public"

# pgAdmin Configuration
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin